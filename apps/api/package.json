    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@clerk/backend": "^3.2.3",
    "@designsprint/shared": "workspace:*",
    "@nestjs/bull": "^10.2.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/throttler": "^6.0.0",
    "@prisma/client": "^5.14.0",
    "bull": "^4.16.0",
    "class-transformer": "^0.5.0",
    "class-validator": "^0.14.0",
    "ioredis": "^5.4.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/bull": "^4.10.0",
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^1.6.1",
    "prisma": "^5.14.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
