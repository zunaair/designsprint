{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "./src",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "paths": {
      "@api/*": ["./src/*"]
    }
  },
  "include": ["src/**/*"]
}
